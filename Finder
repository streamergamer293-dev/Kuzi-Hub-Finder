local function clear()
	for _,v in pairs(list:GetChildren()) do
		if v:IsA("Frame") then v:Destroy() end
	end
end

local function getBrainrots()
	local found = {}

	for _,v in pairs(game:GetDescendants()) do
		if v:IsA("Model") or v:IsA("Folder") then
			local n = string.lower(v.Name)
			if string.find(n,"brainrot") or string.find(n,"coco") or string.find(n,"frigo") then
				table.insert(found, v.Name)
			end
		end
	end

	return found
end

local function getServers()
	local success, result = pcall(function()
		return HttpService:JSONDecode(game:HttpGet(
			"https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Asc&limit=100"
		))
	end)

	if success and result and result.data then
		return result.data
	end

	return {}
end

local function renderBrainrots()
	clear()

	local data = getBrainrots()
	info.Text = "Brainrots: "..#data

	for _,name in pairs(data) do
		local f = Instance.new("Frame", list)
		f.Size = UDim2.new(1,0,0,40)
		f.BackgroundColor3 = Color3.fromRGB(25,25,25)
		Instance.new("UICorner", f)

		local txt = Instance.new("TextLabel", f)
		txt.Size = UDim2.new(0.6,0,1,0)
		txt.BackgroundTransparency = 1
		txt.Text = name
		txt.TextColor3 = Color3.new(1,1,1)
		txt.TextXAlignment = Enum.TextXAlignment.Left

		local join = Instance.new("TextButton", f)
		join.Size = UDim2.new(0.2,0,0.7,0)
		join.Position = UDim2.new(0.6,5,0.15,0)
		join.Text = "JOIN"

		local force = Instance.new("TextButton", f)
		force.Size = UDim2.new(0.2,0,0.7,0)
		force.Position = UDim2.new(0.8,5,0.15,0)
		force.Text = "FORCE"

		join.MouseButton1Click:Connect(function()
			print("Join:", name)
		end)

		force.MouseButton1Click:Connect(function()
			print("Force:", name)
		end)
	end

	list.CanvasSize = UDim2.new(0,0,0,#data*45)
end

scanBtn.MouseButton1Click:Connect(renderBrainrots)

task.spawn(function()
